{
  "compilerOptions": {
    "lib": ["esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": false,
    "esModuleInterop": true,
    "module": "CommonJS",
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "isolatedModules": true,
    "outDir": "dist",
    "rootDir": ".",
    "target": "ES2022"
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
